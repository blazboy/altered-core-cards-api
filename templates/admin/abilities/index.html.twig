{% extends 'admin/layout.html.twig' %}

{% block title %}Abilities — Admin{% endblock %}

{% block content %}

{# ── Tabs ─────────────────────────────────────────────────────────────────── #}
<div class="flex gap-1 mb-6 border-b border-gray-200 dark:border-gray-700">
    {% set tabDefs = [
        {key: 'trigger',   label: 'Triggers',   color: 'blue'},
        {key: 'condition', label: 'Conditions', color: 'indigo'},
        {key: 'effect',    label: 'Effects',    color: 'teal'},
    ] %}
    {% for tab in tabDefs %}
        {% set active = type == tab.key %}
        <a href="{{ path('admin_abilities_index', {type: tab.key}) }}"
           class="px-5 py-2.5 text-sm font-medium rounded-t-lg border-b-2 transition-colors
                  {{ active
                     ? 'border-blue-600 text-blue-600 dark:border-blue-500 dark:text-blue-400 bg-white dark:bg-gray-800'
                     : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 dark:text-gray-400 dark:hover:text-gray-300' }}">
            {{ tab.label }}
            <span class="ml-1.5 px-2 py-0.5 text-xs rounded-full
                         {{ active ? 'bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-300' : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400' }}">
                {{ counts[tab.key]|number_format(0, ',', ' ') }}
            </span>
        </a>
    {% endfor %}
</div>

{# ── Search ───────────────────────────────────────────────────────────────── #}
<div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-4 mb-4">
    <form method="get" class="flex gap-3 items-end">
        <input type="hidden" name="type" value="{{ type }}">
        <div class="flex-1 max-w-sm">
            <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">{{ 'admin.abilities.search_label'|trans }}</label>
            <input type="text"
                   name="q"
                   value="{{ q }}"
                   placeholder="{{ 'admin.abilities.search_placeholder'|trans }}"
                   class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2 dark:bg-gray-700 dark:border-gray-600 dark:text-white">
        </div>
        <button type="submit"
                class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">
            {{ 'admin.abilities.filter_btn'|trans }}
        </button>
        {% if q %}
            <a href="{{ path('admin_abilities_index', {type: type}) }}"
               class="px-4 py-2 text-sm font-medium text-gray-700 bg-white rounded-lg border border-gray-300 hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-600">
                {{ 'admin.abilities.reset_btn'|trans }}
            </a>
        {% endif %}
    </form>
</div>

{# ── Table ────────────────────────────────────────────────────────────────── #}
<div class="bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 dark:border-gray-700">
        <span class="text-sm text-gray-500 dark:text-gray-400">
            <strong class="text-gray-900 dark:text-white">{{ total|number_format(0, ',', ' ') }}</strong>
            {{ type == 'trigger' ? 'trigger(s)' : (type == 'condition' ? 'condition(s)' : 'effect(s)') }}
            {% if q %}<span class="ml-1 text-gray-400">pour « {{ q }} »</span>{% endif %}
        </span>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
            <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                <tr>
                    <th class="px-4 py-3 w-20">ID Altered</th>
                    <th class="px-4 py-3">FR</th>
                    <th class="px-4 py-3">EN</th>
                    <th class="px-4 py-3 w-24">DE</th>
                    <th class="px-4 py-3 w-24">ES</th>
                    <th class="px-4 py-3 w-24">IT</th>
                    <th class="px-4 py-3 w-20 text-center">Support</th>
                    <th class="px-4 py-3 w-16"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                {% for ability in abilities %}
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                    <td class="px-4 py-3 font-mono text-xs text-gray-400">{{ ability.alteredId }}</td>
                    <td class="px-4 py-3 max-w-xs">
                        <p class="truncate text-gray-900 dark:text-white" title="{{ ability.textFr }}">
                            {{ ability.textFr|default('—') }}
                        </p>
                    </td>
                    <td class="px-4 py-3 max-w-xs">
                        <p class="truncate text-gray-500 dark:text-gray-400" title="{{ ability.textEn }}">
                            {{ ability.textEn|default('—') }}
                        </p>
                    </td>
                    <td class="px-4 py-3">
                        <span class="text-xs {{ ability.textDe ? 'text-gray-500' : 'text-gray-300 dark:text-gray-600' }}" title="{{ ability.textDe }}">
                            {{ ability.textDe ? '✓' : '—' }}
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <span class="text-xs {{ ability.textEs ? 'text-gray-500' : 'text-gray-300 dark:text-gray-600' }}" title="{{ ability.textEs }}">
                            {{ ability.textEs ? '✓' : '—' }}
                        </span>
                    </td>
                    <td class="px-4 py-3">
                        <span class="text-xs {{ ability.textIt ? 'text-gray-500' : 'text-gray-300 dark:text-gray-600' }}" title="{{ ability.textIt }}">
                            {{ ability.textIt ? '✓' : '—' }}
                        </span>
                    </td>
                    <td class="px-4 py-3 text-center">
                        {% if ability.isSupport %}
                            <span class="px-2 py-0.5 text-xs font-medium rounded-full bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-300">S</span>
                        {% else %}
                            <span class="text-gray-300 dark:text-gray-600">—</span>
                        {% endif %}
                    </td>
                    <td class="px-4 py-3 text-right">
                        <a href="{{ path('admin_abilities_edit', {type: type, id: ability.id}) }}"
                           class="font-medium text-blue-600 dark:text-blue-500 hover:underline text-xs">
                            Modifier
                        </a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8" class="px-4 py-8 text-center text-gray-400">{{ 'admin.effects.no_results'|trans }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Pagination #}
    {% if totalPages > 1 %}
    <div class="flex items-center justify-between px-6 py-4 border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800">
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
            Page <span class="text-blue-600 dark:text-blue-400">{{ page }}</span> sur {{ totalPages }}
        </span>
        {% set baseParams = {type: type, q: q} %}
        <nav class="flex items-center gap-1">
            {% if page > 1 %}
                <a href="{{ path('admin_abilities_index', baseParams|merge({page: 1})) }}"
                   class="flex items-center justify-center w-9 h-9 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-100 text-sm">«</a>
                <a href="{{ path('admin_abilities_index', baseParams|merge({page: page - 1})) }}"
                   class="flex items-center justify-center w-9 h-9 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-100 text-sm">‹</a>
            {% else %}
                <span class="flex items-center justify-center w-9 h-9 rounded-lg border border-gray-200 dark:border-gray-700 text-gray-300 text-sm cursor-not-allowed">«</span>
                <span class="flex items-center justify-center w-9 h-9 rounded-lg border border-gray-200 dark:border-gray-700 text-gray-300 text-sm cursor-not-allowed">‹</span>
            {% endif %}

            {% if page > 3 %}<span class="flex items-center justify-center w-9 h-9 text-gray-400 text-sm">…</span>{% endif %}
            {% for p in max(1, page - 2)..min(totalPages, page + 2) %}
                <a href="{{ path('admin_abilities_index', baseParams|merge({page: p})) }}"
                   class="flex items-center justify-center w-9 h-9 rounded-lg border text-sm font-semibold
                          {{ p == page ? 'bg-blue-600 border-blue-600 text-white' : 'border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-600' }}">
                    {{ p }}
                </a>
            {% endfor %}
            {% if page < totalPages - 2 %}<span class="flex items-center justify-center w-9 h-9 text-gray-400 text-sm">…</span>{% endif %}

            {% if page < totalPages %}
                <a href="{{ path('admin_abilities_index', baseParams|merge({page: page + 1})) }}"
                   class="flex items-center justify-center w-9 h-9 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-100 text-sm">›</a>
                <a href="{{ path('admin_abilities_index', baseParams|merge({page: totalPages})) }}"
                   class="flex items-center justify-center w-9 h-9 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-100 text-sm">»</a>
            {% else %}
                <span class="flex items-center justify-center w-9 h-9 rounded-lg border border-gray-200 dark:border-gray-700 text-gray-300 text-sm cursor-not-allowed">›</span>
                <span class="flex items-center justify-center w-9 h-9 rounded-lg border border-gray-200 dark:border-gray-700 text-gray-300 text-sm cursor-not-allowed">»</span>
            {% endif %}
        </nav>
    </div>
    {% endif %}
</div>

{% endblock %}
