<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Altered Core API</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: '#6366f1',
                    }
                }
            }
        }
    </script>
    <style>
        pre { scrollbar-width: thin; scrollbar-color: #4b5563 transparent; }
        .endpoint:hover .copy-btn { opacity: 1; }
    </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased">

    <!-- Hero -->
    <div class="border-b border-gray-800 bg-gray-900">
        <div class="max-w-6xl mx-auto px-6 py-16">
            <div class="flex items-center gap-3 mb-6">
                <span class="bg-indigo-500/20 text-indigo-400 text-xs font-semibold px-3 py-1 rounded-full border border-indigo-500/30">v1</span>
                <span class="text-gray-500 text-sm">REST · JSON · API Platform</span>
            </div>
            <h1 class="text-5xl font-bold text-white mb-4">Altered Core API</h1>
            <p class="text-xl text-gray-400 max-w-2xl mb-8">
                Community-maintained card data for the Altered TCG. Cards, card groups, factions, sets and more — all in one place.
            </p>
            <div class="flex flex-wrap gap-3">
                <a href="/api" class="bg-indigo-600 hover:bg-indigo-500 text-white font-medium px-5 py-2.5 rounded-lg transition-colors">
                    Browse API docs →
                </a>
                <a href="/api/cards?page=1" class="bg-gray-800 hover:bg-gray-700 text-gray-200 font-medium px-5 py-2.5 rounded-lg transition-colors">
                    Try it live
                </a>
            </div>
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-6 py-16 space-y-16">

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {% set stats = [
                { label: 'Endpoint', value: '/api/cards' },
                { label: 'Endpoint', value: '/api/card_groups' },
                { label: 'Endpoint', value: '/api/factions' },
                { label: 'Endpoint', value: '/api/sets' },
            ] %}
            {% for stat in stats %}
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-5">
                <div class="text-xs text-gray-500 uppercase tracking-wider mb-1">{{ stat.label }}</div>
                <div class="text-indigo-400 font-mono text-sm font-semibold">{{ stat.value }}</div>
            </div>
            {% endfor %}
        </div>

        <!-- Endpoints -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-2">Endpoints</h2>
            <p class="text-gray-400 mb-8">All responses are paginated (30 items/page by default). Collections return <code class="text-indigo-300 bg-gray-800 px-1.5 py-0.5 rounded text-xs">member</code> and <code class="text-indigo-300 bg-gray-800 px-1.5 py-0.5 rounded text-xs">totalItems</code>.</p>

            <div class="space-y-4">

                {% set endpoints = [
                    {
                        method: 'GET',
                        path: '/api/cards',
                        description: 'List all cards with pagination.',
                        params: [
                            'page=1',
                            'reference=ALT_CORE_B_OR_17_C',
                            'set.reference=CORE',
                            'cardGroup.rarity.reference[]=COMMON',
                            'cardGroup.faction.code=OR',
                        ]
                    },
                    {
                        method: 'GET',
                        path: '/api/card_groups',
                        description: 'List card groups (logical cards). Each group aggregates all prints of a card.',
                        params: [
                            'page=1',
                            'faction.code=OR',
                            'rarity.reference[]=COMMON&rarity.reference[]=RARE',
                            'cards.set.reference=CORE',
                            'mainCost=3',
                            'isBanned=false',
                        ]
                    },
                    {
                        method: 'GET',
                        path: '/api/factions',
                        description: 'List all factions (BR, AX, LY, MU, OR, YZ).',
                        params: []
                    },
                    {
                        method: 'GET',
                        path: '/api/sets',
                        description: 'List all card sets.',
                        params: []
                    },
                ] %}

                {% for endpoint in endpoints %}
                <div class="endpoint bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
                    <div class="flex items-start gap-4 p-5">
                        <span class="shrink-0 bg-emerald-500/15 text-emerald-400 text-xs font-bold px-2.5 py-1 rounded font-mono mt-0.5">{{ endpoint.method }}</span>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-3 mb-1.5">
                                <code class="text-white font-mono text-sm">{{ endpoint.path }}</code>
                            </div>
                            <p class="text-gray-400 text-sm">{{ endpoint.description }}</p>
                        </div>
                        <a href="{{ endpoint.path }}" target="_blank" class="shrink-0 text-xs text-indigo-400 hover:text-indigo-300 border border-indigo-500/30 px-3 py-1.5 rounded-lg transition-colors">
                            Try →
                        </a>
                    </div>
                    {% if endpoint.params is not empty %}
                    <div class="border-t border-gray-800 px-5 py-3">
                        <div class="text-xs text-gray-500 mb-2 uppercase tracking-wider">Filter examples</div>
                        <div class="flex flex-wrap gap-2">
                            {% for param in endpoint.params %}
                            <a href="{{ endpoint.path }}?{{ param }}" target="_blank"
                               class="font-mono text-xs bg-gray-800 hover:bg-gray-700 text-gray-300 px-2.5 py-1 rounded border border-gray-700 transition-colors">
                                ?{{ param }}
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                </div>
                {% endfor %}

            </div>
        </section>

        <!-- Code example -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-2">Quick start</h2>
            <p class="text-gray-400 mb-6">Fetch Bravos common & rare card groups from the CORE set.</p>

            <div class="rounded-xl overflow-hidden border border-gray-800">
                <div class="flex items-center gap-2 bg-gray-800 px-4 py-2.5 border-b border-gray-700">
                    <div class="w-3 h-3 rounded-full bg-red-500/70"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500/70"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500/70"></div>
                    <span class="ml-2 text-xs text-gray-400 font-mono">curl</span>
                </div>
                <pre class="bg-gray-900 p-5 text-sm text-gray-300 overflow-x-auto font-mono leading-relaxed"><span class="text-indigo-400">curl</span> <span class="text-green-400">-H</span> <span class="text-yellow-300">"Accept: application/json"</span> \
  <span class="text-green-400">"https://altered-core-cards-api.toxicity.be/api/card_groups</span><span class="text-gray-400">?faction.code=BR</span>
<span class="text-gray-400">  &rarity.reference[]=COMMON</span>
<span class="text-gray-400">  &rarity.reference[]=RARE</span>
<span class="text-gray-400">  &cards.set.reference=CORE</span>
<span class="text-gray-400">  &page=1"</span></pre>
            </div>

            <div class="mt-4 rounded-xl overflow-hidden border border-gray-800">
                <div class="flex items-center gap-2 bg-gray-800 px-4 py-2.5 border-b border-gray-700">
                    <span class="text-xs text-gray-400 font-mono">response</span>
                    <span class="ml-auto text-xs text-emerald-400 font-semibold">200 OK</span>
                </div>
                <pre class="bg-gray-900 p-5 text-sm text-gray-300 overflow-x-auto font-mono leading-relaxed">{
  <span class="text-indigo-300">"totalItems"</span>: <span class="text-emerald-400">42</span>,
  <span class="text-indigo-300">"member"</span>: [
    {
      <span class="text-indigo-300">"id"</span>:        <span class="text-emerald-400">123</span>,
      <span class="text-indigo-300">"slug"</span>:      <span class="text-yellow-300">"BR-001-C"</span>,
      <span class="text-indigo-300">"name"</span>:      { <span class="text-indigo-300">"fr"</span>: <span class="text-yellow-300">"Nom"</span>, <span class="text-indigo-300">"en"</span>: <span class="text-yellow-300">"Name"</span> },
      <span class="text-indigo-300">"mainCost"</span>:  <span class="text-emerald-400">3</span>,
      <span class="text-indigo-300">"faction"</span>:   { <span class="text-indigo-300">"id"</span>: <span class="text-emerald-400">2</span>, <span class="text-indigo-300">"name"</span>: <span class="text-yellow-300">"Bravos"</span>, <span class="text-indigo-300">"code"</span>: <span class="text-yellow-300">"BR"</span>, <span class="text-indigo-300">"position"</span>: <span class="text-emerald-400">1</span> },
      <span class="text-indigo-300">"rarity"</span>:    { <span class="text-indigo-300">"id"</span>: <span class="text-emerald-400">1</span>, <span class="text-indigo-300">"reference"</span>: <span class="text-yellow-300">"COMMON"</span>, <span class="text-indigo-300">"name"</span>: { <span class="text-indigo-300">"fr"</span>: <span class="text-yellow-300">"Commun"</span>, <span class="text-indigo-300">"en"</span>: <span class="text-yellow-300">"Common"</span> }, <span class="text-indigo-300">"position"</span>: <span class="text-emerald-400">1</span> },
      <span class="text-indigo-300">"isBanned"</span>:  <span class="text-emerald-400">false</span>,
      <span class="text-indigo-300">"isErrated"</span>: <span class="text-emerald-400">false</span>
    }
  ]
}</pre>
            </div>
        </section>

        <!-- Factions -->
        <section>
            <h2 class="text-2xl font-bold text-white mb-6">Factions</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-3">
                {% set factions = [
                    { code: 'BR', name: 'Bravos',  color: 'red' },
                    { code: 'AX', name: 'Axiom',   color: 'blue' },
                    { code: 'LY', name: 'Lyra',    color: 'purple' },
                    { code: 'MU', name: 'Muna',    color: 'green' },
                    { code: 'OR', name: 'Ordis',   color: 'orange' },
                    { code: 'YZ', name: 'Yzmir',   color: 'cyan' },
                ] %}
                {% for faction in factions %}
                <a href="/api/card_groups?faction.code={{ faction.code }}" target="_blank"
                   class="bg-gray-900 border border-gray-800 hover:border-gray-600 rounded-xl p-4 text-center transition-colors group">
                    <div class="text-2xl font-bold text-white mb-1 group-hover:text-indigo-400 transition-colors">{{ faction.code }}</div>
                    <div class="text-xs text-gray-500">{{ faction.name }}</div>
                </a>
                {% endfor %}
            </div>
        </section>

    </div>

    <!-- Footer -->
    <div class="border-t border-gray-800 mt-8">
        <div class="max-w-6xl mx-auto px-6 py-8 flex flex-wrap items-center justify-between gap-4">
            <div class="text-sm text-gray-500">Altered Core API — Community project. Not affiliated with Equinox.</div>
            <a href="/api" class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">API Documentation →</a>
        </div>
    </div>

</body>
</html>
